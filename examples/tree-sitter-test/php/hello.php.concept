  "text": "<?php\n\nclass Greeter {\n    private string $name;\n\n    public function __construct(string $name) {\n        $this->name = $name;\n    }\n\n    public function greet(): string {\n        return \"Hello, {$this->name}!\";\n    }\n}\n\n$g = new Greeter(\"World\");\necho $g->greet() . \"\\n\";\n",

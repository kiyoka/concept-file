  "text": "interface Greeting {\n  message: string;\n  timestamp: Date;\n}\n\nfunction createGreeting(name: string): Greeting {\n  return {\n    message: `Hello, ${name}!`,\n    timestamp: new Date(),\n  };\n}\n\nexport { Greeting, createGreeting };\n",

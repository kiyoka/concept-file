  "text": "package main\n\nimport \"fmt\"\n\ntype Greeter struct {\n\tName string\n}\n\nfunc (g Greeter) Greet() string {\n\treturn fmt.Sprintf(\"Hello, %s!\", g.Name)\n}\n\nfunc main() {\n\tg := Greeter{Name: \"World\"}\n\tfmt.Println(g.Greet())\n}\n",

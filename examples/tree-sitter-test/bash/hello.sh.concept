  "text": "#!/bin/bash\n\ngreet() {\n    local name=\"$1\"\n    echo \"Hello, ${name}!\"\n}\n\nadd() {\n    echo $(( $1 + $2 ))\n}\n\ngreet \"World\"\nadd 3 4\n",

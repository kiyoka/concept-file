  "text": "module Hello where\n\ngreet :: String -> String\ngreet name = \"Hello, \" ++ name ++ \"!\"\n\nadd :: Int -> Int -> Int\nadd x y = x + y\n\nmain :: IO ()\nmain = putStrLn (greet \"World\")\n",

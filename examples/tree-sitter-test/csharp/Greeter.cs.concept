  "text": "namespace Example;\n\npublic class Greeter\n{\n    public string Name { get; set; }\n\n    public Greeter(string name)\n    {\n        Name = name;\n    }\n\n    public string Greet()\n    {\n        return $\"Hello, {Name}!\";\n    }\n}\n",

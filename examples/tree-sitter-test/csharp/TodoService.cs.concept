{
  "concept": "TodoService.cs",
  "version": "1.0",
  "created_at": "2026-03-18T19:42:55.286150+00:00",
  "text": "using System;\nusing System.Collections.Generic;\nusing System.Linq;\n\nnamespace TodoApp\n{\n    public enum Priority\n    {\n        Low,\n        Medium,\n        High\n    }\n\n    public class TodoItem\n    {\n        public int Id { get; set; }\n        public string Title { get; set; }\n        public bool IsComplete { get; set; }\n        public Priority Priority { get; set; }\n        public DateTime CreatedAt { get; set; }\n    }\n\n    public interface ITodoService\n    {\n        TodoItem Add(string title, Priority priority);\n        void Complete(int id);\n        void Delete(int id);\n        List<TodoItem> GetAll();\n        List<TodoItem> GetPending();\n    }\n\n    public class TodoService : ITodoService\n    {\n        private readonly List<TodoItem> _items = new();\n        private int _nextId = 1;\n\n        public TodoItem Add(string title, Priority priority)\n        {\n            var item = new TodoItem\n            {\n                Id = _nextId++,\n                Title = title,\n                Priority = priority,\n                CreatedAt = DateTime.UtcNow\n            };\n            _items.Add(item);\n            return item;\n        }\n\n        public void Complete(int id)\n        {\n            var item = _items.FirstOrDefault(i => i.Id == id);\n            if (item != null) item.IsComplete = true;\n        }\n\n        public void Delete(int id)\n        {\n            _items.RemoveAll(i => i.Id == id);\n        }\n\n        public List<TodoItem> GetAll()\n        {\n            return _items.OrderBy(i => i.Priority).ToList();\n        }\n\n        public List<TodoItem> GetPending()\n        {\n            return _items.Where(i => !i.IsComplete).ToList();\n        }\n    }\n}\n",
  "embed_source": "TodoService.cs\nusing System;\nusing System.Collections.Generic;\nusing System.Linq;\nnamespace TodoApp\n  enum Priority\n  class TodoItem\n    property Id: int\n    property Title: string\n    property IsComplete: bool\n    property Priority: Priority\n    property CreatedAt: DateTime\n  interface ITodoService\n    method Add(string title, Priority priority): void\n    method Complete(int id): void\n    method Delete(int id): void\n    method GetAll(): void\n    method GetPending(): void\n  class TodoService\n    private readonly List<TodoItem> _items = new()\n    private int _nextId = 1\n    method Add(string title, Priority priority): void\n    method Complete(int id): void\n    method Delete(int id): void\n    method GetAll(): void\n    method GetPending(): void",

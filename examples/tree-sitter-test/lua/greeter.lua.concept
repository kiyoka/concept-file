  "text": "local Greeter = {}\nGreeter.__index = Greeter\n\nfunction Greeter.new(name)\n    local self = setmetatable({}, Greeter)\n    self.name = name\n    return self\nend\n\nfunction Greeter:greet()\n    return \"Hello, \" .. self.name .. \"!\"\nend\n\nlocal g = Greeter.new(\"World\")\nprint(g:greet())\n",

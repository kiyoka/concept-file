  "created_at": "2026-03-18T19:33:39.631751+00:00",
  "text": "use std::collections::HashMap;\nuse std::time::{Duration, Instant};\n\npub struct CacheEntry<V> {\n    value: V,\n    expires_at: Instant,\n}\n\npub enum CacheError {\n    NotFound,\n    Expired,\n}\n\npub trait Cacheable: Clone + Send + Sync {}\n\npub struct Cache<K, V> {\n    store: HashMap<K, CacheEntry<V>>,\n    ttl: Duration,\n    max_size: usize,\n}\n\nimpl<K: Eq + std::hash::Hash, V: Cacheable> Cache<K, V> {\n    pub fn new(ttl: Duration, max_size: usize) -> Self {\n        Cache {\n            store: HashMap::new(),\n            ttl,\n            max_size,\n        }\n    }\n\n    pub fn get(&self, key: &K) -> Result<&V, CacheError> {\n        match self.store.get(key) {\n            Some(entry) if entry.expires_at > Instant::now() => Ok(&entry.value),\n            Some(_) => Err(CacheError::Expired),\n            None => Err(CacheError::NotFound),\n        }\n    }\n\n    pub fn set(&mut self, key: K, value: V) {\n        if self.store.len() >= self.max_size {\n            self.evict_expired();\n        }\n        self.store.insert(key, CacheEntry {\n            value,\n            expires_at: Instant::now() + self.ttl,\n        });\n    }\n\n    pub fn remove(&mut self, key: &K) -> bool {\n        self.store.remove(key).is_some()\n    }\n\n    pub fn len(&self) -> usize {\n        self.store.len()\n    }\n\n    fn evict_expired(&mut self) {\n        let now = Instant::now();\n        self.store.retain(|_, entry| entry.expires_at > now);\n    }\n}\n",
  "embed_source": "cache.rs\nuse std::collections::HashMap;\nuse std::time::{Duration, Instant};\nstruct CacheEntry\n  value: V\n  expires_at: Instant\nenum CacheError\n  NotFound\n  Expired\ntrait Cacheable\nstruct Cache\n  store: HashMap<K, CacheEntry<V>>\n  ttl: Duration\n  max_size: usize\nimpl Cache<K, V>\n  fn new(ttl: Duration, max_size: usize) -> Self\n  fn get(&self, key: &K) -> Result<&V, CacheError>\n  fn set(&mut self, key: K, value: V)\n  fn remove(&mut self, key: &K) -> bool\n  fn len(&self) -> usize\n  fn evict_expired(&mut self)"
}
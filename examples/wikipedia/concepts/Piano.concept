CNCP v1 40872
{
  "concept": "Piano",
  "version": "1.0",
  "created_at": "2026-03-14T15:47:24.716403+00:00",
  "text": "A piano is a keyboard instrument that produces sound when its keys are depressed, activating an action mechanism where hammers strike strings. Modern pianos have a row of 88 black and white keys - with the exception of the Bosendörfer and Stuart & Sons pianos - and tuned to a chromatic scale in equal temperament. A musician who specializes in piano is called a pianist.\n",
  "language": "en",

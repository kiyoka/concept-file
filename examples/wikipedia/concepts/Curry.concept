{
  "concept": "Curry",
  "version": "1.0",
  "created_at": "2026-03-14T15:47:42.311101+00:00",
  "text": "Curry is a dish with a spicy sauce or dry flavouring, initially in Indian cuisine, then modified by interchange with the Portuguese, followed by the British, and eventually thoroughly internationalised. Many curries are found in the cuisines of countries in Southeast Asia and East Asia.\n",
  "language": "en",
